---
layout: layouts/base.njk
permalink: "/about/"
title: Club Info
---
<div>
  <h1 class="text-2xl font-bold mb-6">Club Info</h1>

  {% set infoItems = [] %}
  {% for post in collections.all %}
    {% if post.data.tags and ('info' in post.data.tags or 'Info' in post.data.tags or 'meeting-minutes' in post.data.tags or 'Meeting Minutes' in post.data.tags) %}
      {% set infoItems = infoItems.concat([post]) %}
    {% endif %}
  {% endfor %}

  {% if infoItems | length > 0 %}
  <div class="space-y-8">
    {% for post in infoItems | sort(true, false, 'date') %}
      <article class="border-b border-gray-200 dark:border-gray-700 pb-6 last:border-b-0">
        <h2 class="text-xl font-semibold mb-1">
          <a class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors" href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        {% if post.date %}
        <time class="text-sm text-gray-500 dark:text-gray-400 block mb-2" datetime="{{ post.date | htmlDateString }}">
          {{ post.date | readableDate }}
        </time>
        {% endif %}
        {% if post.data.description %}
        <p class="text-gray-700 dark:text-gray-300 mb-3 leading-relaxed">{{ post.data.description }}</p>
        {% endif %}
        {% if post.data.tags %}
        <div class="flex flex-wrap gap-2">
          {% for tag in post.data.tags %}
            <a class="px-2 py-1 rounded text-white text-xs hover:opacity-80 transition-opacity"
               style="background-color: {{ tag | tagColor }}"
               href="/tags/{{ tag | slug }}/">#{{ tag }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>
  {% else %}
  <div class="text-center py-12 bg-gray-50 dark:bg-gray-800/50 rounded-lg">
    <p class="text-gray-500 dark:text-gray-400 text-lg mb-2">No club info posts yet.</p>
    <p class="text-gray-600 dark:text-gray-300 text-sm">Tag posts with <code>info</code> or <code>meeting-minutes</code> to have them appear here.</p>
  </div>
  {% endif %}
</div>
