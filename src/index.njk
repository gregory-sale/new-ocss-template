---
layout: layouts/base.njk
permalink: "/"
title: "Home"
---
<div class="h-feed">
  <!-- Hero Section -->
  <div class="text-center mb-6 pt-8 pb-2">
    <img src="/assets/logo.png" alt="{{ site.name }} logo" id="homepage-main-logo" class="h-36 w-auto mx-auto mb-6" />
    <h1 class="p-name text-4xl font-bold mb-4 float-animation">{{ site.name }}</h1>
    <p class="p-summary text-xl text-gray-600 dark:text-gray-400 mb-6">{{ site.description }}</p>
    <a class="u-url hidden" href="{{ site.url }}/"></a>
    
    <div class="max-w-3xl mx-auto mb-6 text-left">
      <p class="text-lg leading-relaxed text-gray-800 dark:text-gray-200 font-semibold mb-8">
       
      </p>


      <h3 class="text-2xl font-bold mb-4 mt-8 break-words text-gray-900 dark:text-gray-100">Member Newsletters</h3>
      <p class="text-lg leading-relaxed text-gray-700 dark:text-gray-300 mb-6">
        We send out email newsletters regularly during the year. If you are not receiving them, <a href="mailto:admin@ocss.org.uk?subject=OCSS%20Details%20Update" class="text-purple-600 dark:text-purple-400 hover:underline">send us your contact details</a> and best email address. An archive of newsletters is maintained on this site.
      </p>

      <h3 class="text-2xl font-bold mb-4 mt-8 break-words text-gray-900 dark:text-gray-100">Interact</h3>

      <p class="text-lg leading-relaxed text-gray-700 dark:text-gray-300 mb-6">
        <strong>Please submit news of your own and others’ sailing and social activity for publication.</strong> Contact the Webmaster using the link at the very bottom of the sidebar, or the Secretary to get in touch with another member. Any news or photos are welcome. Please also inform us of any changes to your contact details – particularly email address.
      </p>
    </div>
  </div>

  <!-- Random Photo Showcase -->
  <div class="mb-12">
    <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
      📸 Photo Showcase
    </h2>
    <div id="photo-carousel" class="flex overflow-x-auto snap-x gap-4 pb-4 scroll-smooth" style="scrollbar-width: none;">
      <!-- Photos injected by JS -->
    </div>
    <!-- Hidden JSON payload -->
    <script id="carousel-images" type="application/json">
      {{ collections.allImages | json | safe }}
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        try {
          const rawData = document.getElementById('carousel-images').textContent;
          const images = JSON.parse(rawData);
          if (images && images.length > 0) {
            // Shuffle and pick 15
            const shuffled = images.sort(() => 0.5 - Math.random());
            const selected = shuffled.slice(0, 15);
            
            const carousel = document.getElementById('photo-carousel');
            selected.forEach(img => {
              // Create link wrapper
              const a = document.createElement('a');
              a.href = img.postUrl;
              a.className = "flex-shrink-0 snap-center group block relative overflow-hidden rounded-lg shadow-md";
              // Fixed dimensions for the images
              a.style.width = "250px";
              a.style.height = "200px";
              
              // Image
              const imgEl = document.createElement('img');
              imgEl.src = img.src;
              imgEl.alt = img.alt || img.postTitle;
              imgEl.className = "w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 bg-gray-100 dark:bg-gray-800";
              
              // Hover overlay with title
              const overlay = document.createElement('div');
              overlay.className = "absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-4 text-center";
              const title = document.createElement('span');
              title.className = "text-white text-sm font-semibold";
              title.textContent = img.postTitle;
              
              overlay.appendChild(title);
              a.appendChild(imgEl);
              a.appendChild(overlay);
              carousel.appendChild(a);
            });
          }
        } catch (e) {
          console.error("Failed to load carousel images", e);
        }
      });
    </script>
  </div>

  <!-- Recent Posts -->
  <div class="mb-8">
    <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
      ✍️ Recent Posts
    </h2>

    {% set recent = collections.newsPosts | default([]) %}
    {% if (recent | length) == 0 %}
      {% set recent = collections.searchIndex | default([]) %}
    {% endif %}

    {% if recent | length > 0 %}
    <div class="space-y-8">
      {% for post in recent | head(5) %}
        {% set url = post.url or post.id %}
        {% set title = (post.data and post.data.title) or post.title %}
        {% set dateVal = post.date %}
        {% set desc = (post.data and post.data.description) or post.description or (post.templateContent | default('') | striptags | truncate(160)) %}
        {% set tags = (post.data and post.data.tags) or post.tags or [] %}
        <article class="h-entry border-b border-gray-200 dark:border-gray-700 pb-6 last:border-b-0">
          <h3 class="p-name text-xl font-semibold mb-2">
            <a class="u-url hover:text-purple-600 dark:hover:text-purple-400 transition-colors" href="{{ url }}">
              {{ title }}
            </a>
          </h3>
          {% if dateVal %}
          <time class="dt-published text-sm text-gray-500 dark:text-gray-400 block mb-3" datetime="{{ dateVal | htmlDateString }}">
            {{ dateVal | readableDate }}
          </time>
          {% endif %}
          {% if desc %}
          <p class="p-summary text-gray-700 dark:text-gray-300 mb-3 leading-relaxed">
            {{ desc | safe }}
          </p>
          {% endif %}
          {% if tags %}
          <div class="flex flex-wrap gap-2">
            {% for tag in tags %}
              <a class="p-category px-2 py-1 rounded text-white text-xs hover:opacity-80 transition-opacity" 
                 style="background-color: {{ tag | tagColor }}" 
                 href="/tags/{{ tag | slug }}/">#{{ tag }}</a>
            {% endfor %}
          </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <div class="text-center mt-8">
      <!-- More button -->
      <a href="/news/" class="inline-flex items-center gap-2 text-purple-600 dark:text-purple-400 hover:underline">
        View All Updates →
      </a>
    </div>
    {% else %}
    <div class="text-center py-12 bg-gray-50 dark:bg-gray-800/50 rounded-lg">
      <p class="text-gray-500 dark:text-gray-400 text-lg mb-4">No posts yet!</p>
      <p class="text-gray-600 dark:text-gray-300">This is where thoughtful writing will appear. Stay tuned! 📝</p>
    </div>
    {% endif %}
  </div>

  <!-- Quick Links -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-12">
    <a href="/info/" class="block p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">
      <div class="text-2xl mb-2">ℹ️</div>
      <h3 class="font-semibold text-blue-800 dark:text-blue-200">Club Info</h3>
      <p class="text-sm text-blue-600 dark:text-blue-300">Info and meeting minutes</p>
    </a>
    
    <a href="/history/" class="block p-4 bg-green-50 dark:bg-green-900/20 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">
      <div class="text-2xl mb-2">📜</div>
      <h3 class="font-semibold text-green-800 dark:text-green-200">OCSS History</h3>
      <p class="text-sm text-green-600 dark:text-green-300">Club history and heritage</p>
    </a>
    
    <a href="/sitemap/" class="block p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-900/30 transition-colors">
      <div class="text-2xl mb-2">🗺️</div>
      <h3 class="font-semibold text-purple-800 dark:text-purple-200">Explore this site</h3>
      <p class="text-sm text-purple-600 dark:text-purple-300">Complete directory of pages</p>
    </a>
  </div>
</div>
